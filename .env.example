# ============================================
# BigBets Studio - Environment Variables
# ============================================

# App / NextAuth (email OTP — no OAuth)
# Must match the origin you open in the browser (include port if not 80/443).
NEXTAUTH_URL=http://localhost:3000
# Required — generate e.g. openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-change-in-production
# Optional behind reverse proxies: AUTH_TRUST_HOST=true
#
# If you see JWEDecryptionFailed / JWT_SESSION_ERROR:
# - Keep NEXTAUTH_SECRET stable; clear cookies after changing it.
# - Use one port consistently; NEXTAUTH_URL must match.

# PostgreSQL (Prisma / Supabase)
# Put DATABASE_URL in `.env.local` (Next.js + our npm scripts). Prisma CLI alone only reads `.env`,
# so use: npm run db:push  (not raw npx prisma db push), OR duplicate DATABASE_URL into `.env`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Email (Nodemailer / SMTP) — required for login OTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-user@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="BigBets Studio <noreply@yourdomain.com>"

# OR use Resend (if you wire it in code)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional — min ms between Prisma user lookups in NextAuth JWT callback (default 300000 = 5 min). Lower = fresher isAdmin, more DB load.
# JWT_PROFILE_REFRESH_MS=300000

# Checkout copy: demo (mock gateway) vs live (real gateway — set when Razorpay etc. is wired)
NEXT_PUBLIC_PAYMENT_MODE=demo

# Mock payment (optional — random failure rate 0–1 for stress testing)
# MOCK_PAYMENT_FAILURE_RATE=0.1

# Admin (comma-separated; these emails get isAdmin on first signup)
ADMIN_EMAILS=admin@bigbetsstudio.com,support@bigbetsstudio.com

# Optional — booking alerts (cancellations, etc.). Comma-separated. Falls back to ADMIN_EMAILS, then NEXT_PUBLIC_STUDIO_EMAIL / site config.
# ADMIN_BOOKING_EMAIL=bookings@yourdomain.com

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hi! I want to book a session at BigBets Studio.

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STUDIO_ADDRESS=803B Tower2A Panchsheel Wellington, Crossing Republik, Ghaziabad
NEXT_PUBLIC_STUDIO_EMAIL=support@bigbetsstudio.com
NEXT_PUBLIC_STUDIO_PHONE=+91-9999999999
